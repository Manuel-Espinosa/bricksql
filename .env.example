# ── Required ─────────────────────────────────────────────────────────────────
BRICKSQL_USER=admin
BRICKSQL_PASSWORD=changeme
JWT_SECRET=change-this-to-a-random-secret-string

# ── Optional (production) ─────────────────────────────────────────────────────
PORT=3000
DATA_DIR=./data

# ── Dev only (docker-compose.dev.yml) ─────────────────────────────────────────
